@page "/"

<PageTitle>SICUENSA</PageTitle>

<MudImage Src="logo-gob.png" Width="400"/>
@*Keyframes by https://animate.style/*@
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<style type="text/css">

    .bounceIn {
        opacity: 0;
        animation-delay: 0.5s;
        animation-duration: 0.5s;
        animation-name: bounceIn;
        animation-fill-mode: forwards;
    }

    .bounceOut {
        animation-duration: 0.5s;
        animation-name: bounceOut;
        animation-fill-mode: forwards;
    }

    .backInDown {
        opacity: 0;
        animation-delay: 0.5s;
        animation-duration: 0.5s;
        animation-name: backInDown;
        animation-fill-mode: forwards;
    }

    .backOutDown {
        animation-duration: 0.5s;
        animation-name: backOutDown;
        animation-fill-mode: forwards;
    }

    .rotateIn {
        opacity: 0;
        animation-delay: 0.5s;
        animation-duration: 0.5s;
        animation-name: rotateIn;
        animation-fill-mode: forwards;
    }

    .rotateOut {
        animation-duration: 0.5s;
        animation-name: rotateOut;
        animation-fill-mode: forwards;
    }
</style>
<!--carrusel-->
<MudCarousel Class="mud-width-fill" Style="height:250px;" TData="object" AutoCycle="true">
    <MudCarouselItem Color="@Color.Primary" Transition="Transition.Slide">
        <div class="d-flex flex-column flex-column justify-center" style="height:100%">
            <MudImage Src="/Banner.jpg" Alt="Banner" Elevation="25" Class="ms-xxl-5"/>
        </div>
    </MudCarouselItem>
    <MudCarouselItem Color="@Color.Secondary" Transition="Transition.Fade">
        <div class="d-flex flex-column flex-column justify-center" style="height:100%">
            <MudImage Src="/estudio.png" Alt="Banner" Elevation="25" Class="ms-xxl-5"/>
        </div>
    </MudCarouselItem>
    <MudCarouselItem Color="@Color.Tertiary" Transition="Transition.Custom" CustomTransitionEnter="bounceIn" CustomTransitionExit="bounceOut">
        <div class="d-flex flex-column flex-column justify-center" style="height:100%">
            <MudImage Src="/Banner3.jpg" Alt="Banner" Elevation="25" Class="ms-xxl-5"/>
        </div>
    </MudCarouselItem>
    <MudCarouselItem Transition="Transition.Custom" CustomTransitionEnter="backInDown" CustomTransitionExit="backOutDown">
        <div class="d-flex flex-column flex-column justify-center" style="height:100%">
            <MudImage Src="/Yoga.jpg" Alt="Banner" Elevation="25" Class="ms-xxl-5"/>
        </div>
    </MudCarouselItem>
    <MudCarouselItem Transition="Transition.Custom" CustomTransitionEnter="rotateIn" CustomTransitionExit="rotateOut">
        <div class="d-flex flex-column flex-column justify-center" style="height:100%">
            <MudImage Src="/Yoga-mujeres.jpg" Alt="Banner" Elevation="25" Class="ms-xxl-5"/>
        </div>
    </MudCarouselItem>
</MudCarousel>
<!--contenido 1-->
<MudContainer Class="mt-16">
    <MudText Typo="Typo.h2" Align="Align.Center" GutterBottom="true">Dirección de Planificación de Salud</MudText>
    <MudText Typo="Typo.h3" Align="Align.Center" GutterBottom="true">Departamento de Economía de la Salud</MudText>
    <MudText Align="Align.Center">CUENTAS DE SALUD</MudText>
    <MudGrid Class="mt-8">
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="25" Class="rounded-lg pb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h4" Align="Align.Center">Metodología SHA 2011</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <div class="d-flex justify-center">
                        <MudText Typo="Typo.h5">Definición</MudText>
                    </div>
                    <MudList T="string" Class="mx-auto mt-4" Style="width:300px;">
                        <MudListItem Icon="@Icons.Material.Filled.LiveHelp">
                            “Las cuentas de salud presentan una descripción sistemática de los flujos financieros relativos al consumo de 
                            los bienes y servicios de salud” 

                            Su intención es describir la salud 
                            desde la perspectiva del gasto.”
                        </MudListItem>
                    </MudList>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="25" Class="rounded-lg pb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h4" Align="Align.Center">Cuentas de Salud</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <div class="d-flex justify-center">
                        <MudText Typo="Typo.h5">Se asocian a tres dimensiones:</MudText>
                    </div>
                    <MudList T="string" Class="mx-auto mt-4" Style="width:300px;">
                        <MudListItem Icon="@Icons.Material.Filled.LiveHelp">
                            Esquemas del financiamiento – Financiamiento
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.LiveHelp">
                            Esquemas de las funciones de salud – Consumo 

                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.LiveHelp">
                            Esquema de los proveedores de atención de salud - Provisión
                        </MudListItem>
                    </MudList>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="12" md="4">
            <MudCard Elevation="25" Class="rounded-lg pb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h4" Align="Align.Center">Formulario</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <div class="d-flex justify-center">
                        <MudText Typo="Typo.h3"></MudText>
                    </div>
                    <MudList T="string" Class="mx-auto mt-4" Style="width:300px;">
                        <MudListItem Icon="@Icons.Material.Filled.LiveHelp">
                            Unlimited something
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.LiveHelp">
                            10 something
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.LiveHelp">
                            No something
                        </MudListItem>
                    </MudList>
                </MudCardContent>
                <MudCardActions Class="d-flex justify-center">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Style="width:50%;">Start now</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>
<!--contenido 2-->
<MudContainer Class="mt-16 px-8" MaxWidth="MaxWidth.False">
    <MudGrid>
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Elevation="2" Class="pa-4" Style="height: 200px;">Otorgan más importancia al consumo final de bienes y servicios de la población que a la producción.
                En estudios previos en otros países se muestran la falta 
                de correspondencia entre el gasto real, las políticas públicas 
                y un alto grado de inequidad en el financiamiento a nivel 
                de la región.
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Elevation="2" Class="pa-4" Style="height: 200px;">Se asocian a tres dimensiones:
                Esquemas del financiamiento – Financiamiento
                Esquemas de las funciones de salud – Consumo
                Esquema de los proveedores de atención de salud - Provisión
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudGrid>
                <MudItem xs="12">
                    <div class="d-flex flex-column flex-column justify-center" style="height:100%">
                        <MudImage Src="/SHA.png" Alt="Banner" Elevation="25" Class="ms-xxl-5"/>
                    </div>
                </MudItem>
                <MudItem xs="12">
                    <div class="d-flex flex-column flex-column justify-center" style="height:100%">
                        <MudImage Src="/ghed.png" Alt="Banner" Elevation="25" Class="ms-xxl-5"/>
                    </div>
                </MudItem>
                <MudItem xs="12">
                    <MudPaper Elevation="2" Class="pa-4" Style="height: 200px;">
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudPaper Elevation="2" Class="pa-4" Style="height: 100%"></MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Elevation="2" Class="pa-4" Style="height: 200px;"></MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Elevation="2" Class="pa-4" Style="height: 200px;"></MudPaper>
        </MudItem>
        <MudItem xs="12" sm="12" md="4">
            <MudPaper Elevation="2" Class="pa-4" Style="height: 200px;"></MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>
<!--contenido 3-->